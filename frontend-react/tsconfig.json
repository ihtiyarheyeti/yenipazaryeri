{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "skipLibCheck": true,
    "noEmit": true,

    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "types": ["node"]
  },
  "include": ["src", "src/types.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
